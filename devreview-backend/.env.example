# --- Core ---
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
APP_URL=http://localhost:5173
API_URL=http://localhost:8080

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=super-secret-jwt

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- AI Gateway (OpenAI-compatible) ---
AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1
AI_GATEWAY_API_KEY=
AI_MODEL_DEFAULT=google/gemini-2.5-flash
AI_MODEL_REVIEW=google/gemini-2.5-pro

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Encryption (AES-256-GCM, 32-byte hex) ---
ENCRYPTION_KEY=

# --- Sandbox runner (online IDE) ---
SANDBOX_PROVIDER=local
SANDBOX_IMAGE=node:20-bookworm
